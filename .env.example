# Uptime-Kuma with SQLite Backup - Environment Variables

# =============================================================================
# Version Configuration
# =============================================================================
UPTIME_KUMA_VERSION=2.0.2

# =============================================================================
# Azure Blob Storage Configuration (Required for backup)
# =============================================================================
AZURE_STORAGE_ACCOUNT=your_storage_account_name
AZURE_STORAGE_KEY=your_storage_account_key

# =============================================================================
# Database Backup Settings
# =============================================================================
DB_BACKUP_ENABLED=true
DB_BACKUP_INTERVAL=5m
DB_FAIL_ON_RESTORE_ERROR=false
AZURE_BACKUP_CONTAINER=kuma-backup
AZURE_BACKUP_FILENAME=kuma.db

# =============================================================================
# Upload Sync Settings (for icons and images)
# =============================================================================
UPLOAD_SYNC_ENABLED=true
UPLOAD_SYNC_INTERVAL=5m
AZURE_UPLOAD_CONTAINER=kuma-uploads
